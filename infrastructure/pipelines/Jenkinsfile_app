#!/usr/bin/env groovy

/**
 * App Stack Deployment Pipeline
 * Deploys App-Specific Policies Stack - Frequent changes per sprint
 */

pipeline {
    agent any
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }
    
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'test', 'prod'],
            description: 'Select the environment'
        )
        choice(
            name: 'ACTION',
            choices: ['CREATE', 'UPDATE', 'DELETE'],
            description: 'CloudFormation action'
        )
        string(
            name: 'AWS_REGION',
            defaultValue: 'us-east-1',
            description: 'AWS region'
        )
        string(
            name: 'CF_TEMPLATES_BUCKET',
            defaultValue: 'your-cf-templates-bucket',
            description: 'S3 bucket with templates'
        )
        string(
            name: 'CHANGE_DESCRIPTION',
            defaultValue: 'Sprint-release',
            description: 'Description of changes for audit'
        )
    }
    
    environment {
        PROJECT_NAME = 'ascend'
        STACK_TYPE = 'app'
    }
    
    stages {
        stage('Preparation') {
            steps {
                script {
                    checkout scm
                    
                    echo "========== App Stack Deployment =========="
                    echo "Environment: ${params.ENVIRONMENT}"
                    echo "Action: ${params.ACTION}"
                    echo "Region: ${params.AWS_REGION}"
                    echo "Changes: ${params.CHANGE_DESCRIPTION}"
                    echo "========================================"
                }
            }
        }
        
        stage('Code Review') {
            when {
                expression { params.ENVIRONMENT == 'prod' && params.ACTION == 'UPDATE' }
            }
            steps {
                script {
                    input(message: "Review policy changes and approve for PRODUCTION", ok: 'Approve')
                }
            }
        }
        
        stage('Validate & Upload') {
            steps {
                script {
                    // Validate template
                    sh """
                        aws cloudformation validate-template \
                            --template-body file://infrastructure/cloudformation/app/app_policies.yaml \
                            --region ${params.AWS_REGION}
                    """
                    
                    // Show change set for updates
                    if (params.ACTION == 'UPDATE') {
                        sh """
                            echo "Generating change set..."
                            aws cloudformation create-change-set \
                                --stack-name ${PROJECT_NAME}-app-stack-${params.ENVIRONMENT} \
                                --change-set-name app-changeset-\$(date +%s) \
                                --template-body file://infrastructure/cloudformation/app/app_policies.yaml \
                                --parameters file://infrastructure/configs/${params.ENVIRONMENT}/app_parameters.json \
                                --capabilities CAPABILITY_NAMED_IAM \
                                --region ${params.AWS_REGION} || true
                        """
                    }
                    
                    // Upload to S3
                    sh """
                        aws s3 cp infrastructure/cloudformation/app/app_policies.yaml \
                            s3://${params.CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/app/ \
                            --region ${params.AWS_REGION}
                    """
                }
            }
        }
        
        stage('Deploy') {
            steps {
                script {
                    def stackName = "${PROJECT_NAME}-app-stack-${params.ENVIRONMENT}"
                    def templatePath = "${WORKSPACE}/infrastructure/cloudformation/app/app_policies.yaml"
                    def paramFile = "${WORKSPACE}/infrastructure/configs/${params.ENVIRONMENT}/app_parameters.json"
                    
                    sh """
                        ./infrastructure/pipelines/utilities/deploy_stack.sh \
                            ${stackName} \
                            ${templatePath} \
                            ${paramFile} \
                            ${params.ACTION} \
                            ${params.AWS_REGION}
                    """
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
        
        success {
            script {
                echo "✓ App Stack deployment completed successfully"
                echo "Change Description: ${params.CHANGE_DESCRIPTION}"
            }
        }
    }
}
