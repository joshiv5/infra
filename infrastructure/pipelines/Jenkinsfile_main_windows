#!/usr/bin/env groovy

/**
 * Main Orchestrator Pipeline - Windows/PowerShell Compatible
 * Deploys entire infrastructure stack hierarchy via nested stacks (Core -> Base -> App)
 * Single deployment point - the main template orchestrates all nested stacks
 */

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '5'))
        timeout(time: 2, unit: 'HOURS')
        timestamps()
    }
    
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'test', 'prod'],
            description: 'Select the environment to deploy to'
        )
        choice(
            name: 'ACTION',
            choices: ['CREATE', 'UPDATE', 'DELETE'],
            description: 'CloudFormation action to perform'
        )
        string(
            name: 'AWS_REGION',
            defaultValue: 'eu-central-1',
            description: 'AWS region for deployment'
        )
        string(
            name: 'CF_TEMPLATES_BUCKET',
            defaultValue: 'ascend-test-poc',
            description: 'S3 bucket containing CloudFormation templates'
        )
        booleanParam(
            name: 'DEPLOY_APP',
            defaultValue: true,
            description: 'Deploy App Stack? Set to false to skip app-only updates'
        )
    }
    
    environment {
        PROJECT_NAME = 'ascend'
	AWS_CREDS = credentials('aws-credentials')
        AWS_DEFAULT_REGION = "${params.AWS_REGION}"
        TEMPLATES_PATH = "${WORKSPACE}\\infrastructure\\cloudformation"
        CONFIGS_PATH = "${WORKSPACE}\\infrastructure\\configs"
        ENVIRONMENT = "${params.ENVIRONMENT}"
        ACTION = "${params.ACTION}"
        MAIN_STACK_NAME = "${PROJECT_NAME}-main-stack-${params.ENVIRONMENT}"
    }
    
    stages {
        stage('Validation') {
            steps {
                script {
                    echo "========== Pipeline Configuration =========="
                    echo "Project: ${PROJECT_NAME}"
                    echo "Environment: ${ENVIRONMENT}"
                    echo "Action: ${ACTION}"
                    echo "AWS Region: ${AWS_DEFAULT_REGION}"
                    echo "CF Templates Bucket: ${CF_TEMPLATES_BUCKET}"
                    echo "Deploy App Stack: ${params.DEPLOY_APP}"
                    echo "Main Stack Name: ${MAIN_STACK_NAME}"
                    echo "==========================================="
                    
                    // Validate environment parameter
                    if (!['dev', 'test', 'prod'].contains(ENVIRONMENT)) {
                        error("Invalid environment: ${ENVIRONMENT}")
                    }
                    
                    // Validate action parameter
                    if (!['CREATE', 'UPDATE', 'DELETE'].contains(ACTION)) {
                        error("Invalid action: ${ACTION}")
                    }
                    
                    // Production approval gate
                    if (ENVIRONMENT == 'prod' && ACTION in ['CREATE', 'DELETE']) {
                        input(message: "⚠️  PRODUCTION DEPLOYMENT ⚠️\n\nYou are about to ${ACTION} infrastructure in PRODUCTION!\n\nStack: ${MAIN_STACK_NAME}\n\nContinue?", ok: 'DEPLOY TO PRODUCTION')
                    }
                }
            }
        }
        
        stage('Checkout') {
            steps {
                script {
                    echo "📦 Checking out source code..."
                    checkout scm
                    echo "✓ Code checked out successfully"
                }
            }
        }
        
        stage('Validate Templates') {
            steps {
                script {
                    echo "🔍 Validating CloudFormation templates..."
                    
                    // Validate main template
                    powershell """
                        aws cloudformation validate-template `
                            --template-body file://${TEMPLATES_PATH}/main/main_template.yaml `
                            --region ${AWS_DEFAULT_REGION} | Out-Null
                        Write-Host "✓ Main template validated"
                    """
                    
                    // Validate nested templates
                    def nestedTemplates = [
                        'core/core_iam_roles.yaml',
                        'base/base_s3_kms.yaml',
                        'app/app_policies.yaml',
                        'app/cumulus/roles.yaml',
                        'app/retina/roles.yaml',
                        'app/dataapi/roles.yaml',
                        'app/leanretina/roles.yaml'
                    ]
                    
                    nestedTemplates.each { template ->
                        powershell """
                            aws cloudformation validate-template `
                                --template-body file://${TEMPLATES_PATH}/${template} `
                                --region ${AWS_DEFAULT_REGION} | Out-Null
                            Write-Host "✓ ${template} validated"
                        """
                    }
                    
                    echo "✓ All templates validated successfully"
                }
            }
        }
        
        stage('Upload Templates to S3') {
            steps {
                script {
                    echo "📤 Uploading CloudFormation templates to S3..."
                    
                    powershell """
                        # Upload core template
                        aws s3 cp "${TEMPLATES_PATH}/core/core_iam_roles.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/core/core_iam_roles.yaml" `
                            --region ${AWS_DEFAULT_REGION}
                        
                        # Upload base template
                        aws s3 cp "${TEMPLATES_PATH}/base/base_s3_kms.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/base/base_s3_kms.yaml" `
                            --region ${AWS_DEFAULT_REGION}
                        
                        # Upload app template
                        aws s3 cp "${TEMPLATES_PATH}/app/app_policies.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/app/app_policies.yaml" `
                            --region ${AWS_DEFAULT_REGION}

                        # Upload app role templates
                        aws s3 cp "${TEMPLATES_PATH}/app/cumulus/roles.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/app/cumulus/roles.yaml" `
                            --region ${AWS_DEFAULT_REGION}

                        aws s3 cp "${TEMPLATES_PATH}/app/retina/roles.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/app/retina/roles.yaml" `
                            --region ${AWS_DEFAULT_REGION}

                        aws s3 cp "${TEMPLATES_PATH}/app/dataapi/roles.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/app/dataapi/roles.yaml" `
                            --region ${AWS_DEFAULT_REGION}

                        aws s3 cp "${TEMPLATES_PATH}/app/leanretina/roles.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/app/leanretina/roles.yaml" `
                            --region ${AWS_DEFAULT_REGION}
                        
                        # Upload main template
                        aws s3 cp "${TEMPLATES_PATH}/main/main_template.yaml" `
                            "s3://${CF_TEMPLATES_BUCKET}/infrastructure/cloudformation/main/main_template.yaml" `
                            --region ${AWS_DEFAULT_REGION}
                        
                        Write-Host "✓ All templates uploaded to S3"
                    """
                }
            }
        }
        
stage('Deploy Main Stack') {
    steps {
        script {
            echo "🚀 Deploying Main Stack (${MAIN_STACK_NAME})..."

            def paramFile = "${CONFIGS_PATH}\\${ENVIRONMENT}\\main_parameters.json"
            def templateUrl = "https://${CF_TEMPLATES_BUCKET}.s3.${AWS_DEFAULT_REGION}.amazonaws.com/infrastructure/cloudformation/main/main_template.yaml"

            echo "Template URL: ${templateUrl}"
            echo "Parameter File: ${paramFile}"

            try {

                powershell """
                Write-Host "Checking if stack exists..."

                \$stackExists = \$false
                \$ErrorActionPreference = "SilentlyContinue"

                aws cloudformation describe-stacks `
                    --stack-name ${MAIN_STACK_NAME} `
                    --region ${AWS_DEFAULT_REGION} | Out-Null

                if (\$LASTEXITCODE -eq 0) {
                    \$stackExists = \$true
                    Write-Host "Stack exists"
                }
                else {
                    \$stackExists = \$false
                    Write-Host "Stack does not exist"
                }

                \$ErrorActionPreference = "Continue"

                if (\$stackExists -and "${ACTION}" -eq "UPDATE") {

                    Write-Host "📋 Updating stack..."

                    aws cloudformation update-stack `
                        --stack-name ${MAIN_STACK_NAME} `
                        --template-url "${templateUrl}" `
                        --parameters file://${paramFile} `
                        --region ${AWS_DEFAULT_REGION} `
                        --capabilities CAPABILITY_NAMED_IAM

                }
                elseif (-not \$stackExists -and "${ACTION}" -eq "CREATE") {

                    Write-Host "✨ Creating stack..."

                    aws cloudformation create-stack `
                        --stack-name ${MAIN_STACK_NAME} `
                        --template-url "${templateUrl}" `
                        --parameters file://${paramFile} `
                        --region ${AWS_DEFAULT_REGION} `
                        --capabilities CAPABILITY_NAMED_IAM `
                        --tags `
                            Key=Project,Value=${PROJECT_NAME} `
                            Key=Environment,Value=${ENVIRONMENT} `
                            Key=ManagedBy,Value=Jenkins

                }
                elseif (\$stackExists -and "${ACTION}" -eq "DELETE") {

                    Write-Host "🗑️ Deleting stack..."

                    aws cloudformation delete-stack `
                        --stack-name ${MAIN_STACK_NAME} `
                        --region ${AWS_DEFAULT_REGION}

                }
                else {

                    Write-Host "Invalid state"
                    exit 1

                }
                """

                echo "⏳ Waiting for stack operation..."

                powershell """
                if ("${ACTION}" -eq "DELETE") {

                    aws cloudformation wait stack-delete-complete `
                        --stack-name ${MAIN_STACK_NAME} `
                        --region ${AWS_DEFAULT_REGION}

                }
                elseif ("${ACTION}" -eq "CREATE") {

                    aws cloudformation wait stack-create-complete `
                        --stack-name ${MAIN_STACK_NAME} `
                        --region ${AWS_DEFAULT_REGION}

                }
                elseif ("${ACTION}" -eq "UPDATE") {

                    aws cloudformation wait stack-update-complete `
                        --stack-name ${MAIN_STACK_NAME} `
                        --region ${AWS_DEFAULT_REGION}

                }
                """

                echo "✓ Stack deployment completed successfully"

            } catch (Exception e) {

                echo "⚠️ Stack deployment failed"

                powershell """
                Write-Host "Stack Status:"
                aws cloudformation describe-stacks `
                    --stack-name ${MAIN_STACK_NAME} `
                    --region ${AWS_DEFAULT_REGION} `
                    --query 'Stacks[0].[StackStatus,StackStatusReason]' `
                    --output text
                """

                error("Main Stack deployment failed")

            }
        }
    }
}        
        stage('Verify Deployment') {
            when {
                expression { params.ACTION in ['CREATE', 'UPDATE'] }
            }
            steps {
                script {
                    echo "✅ Verifying deployment..."
                    
                    powershell """
                        Write-Host "Stack Status:"
                        aws cloudformation describe-stacks `
                            --stack-name ${MAIN_STACK_NAME} `
                            --region ${AWS_DEFAULT_REGION} `
                            --query 'Stacks[0].[StackStatus,CreationTime,LastUpdatedTime]' `
                            --output table
                        
                        Write-Host ""
                        Write-Host "Nested Stacks:"
                        aws cloudformation list-stacks `
                            --region ${AWS_DEFAULT_REGION} `
                            --stack-status-filter CREATE_COMPLETE UPDATE_COMPLETE `
                            --query "StackSummaries[?contains(StackName, '${ENVIRONMENT}')].StackName" `
                            --output table
                        
                        Write-Host ""
                        Write-Host "Stack Resources:"
                        aws cloudformation list-stack-resources `
                            --stack-name ${MAIN_STACK_NAME} `
                            --region ${AWS_DEFAULT_REGION} `
                            --query 'StackResourceSummaries[].{Type:ResourceType,Status:ResourceStatus,Name:LogicalResourceId}' `
                            --output table
                    """
                    
                    echo "✓ Deployment verified successfully"
                }
            }
        }
        
        stage('Generate Report') {
            when {
                expression { params.ACTION in ['CREATE', 'UPDATE'] }
            }
            steps {
                script {
                    echo "📊 Generating deployment report..."
                    
                    powershell """
                        \$report = @"
Deployment Report
================
Project: ${PROJECT_NAME}
Environment: ${ENVIRONMENT}
Stack Name: ${MAIN_STACK_NAME}
Region: ${AWS_DEFAULT_REGION}
Action: ${ACTION}
Build Number: ${BUILD_NUMBER}
Build URL: ${BUILD_URL}
Timestamp: \$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')

Stack Outputs:
\$(aws cloudformation describe-stacks `
    --stack-name ${MAIN_STACK_NAME} `
    --region ${AWS_DEFAULT_REGION} `
    --query 'Stacks[0].Outputs' `
    --output table 2>\$null)

Nested Stacks:
\$(aws cloudformation list-stacks `
    --region ${AWS_DEFAULT_REGION} `
    --stack-status-filter CREATE_COMPLETE UPDATE_COMPLETE `
    --query "StackSummaries[?contains(StackName, '${ENVIRONMENT}')].StackName" `
    --output table 2>\$null)
"@
                        
                        Set-Content -Path "${WORKSPACE}/deployment_report.txt" -Value \$report
                        Get-Content "${WORKSPACE}/deployment_report.txt"
                    """
                    
                    archiveArtifacts artifacts: 'deployment_report.txt', allowEmptyArchive: true
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "🏁 Pipeline execution completed"
            }
        }
        
        success {
            script {
                echo "✅ Pipeline completed successfully!"
                echo "Stack: ${MAIN_STACK_NAME}"
                echo "Environment: ${ENVIRONMENT}"
                echo "Status: SUCCESS"
            }
        }
        
        failure {
            script {
                echo "❌ Pipeline failed!"
                echo "Stack: ${MAIN_STACK_NAME}"
                echo "Environment: ${ENVIRONMENT}"
                
                // Attempt to show stack events for debugging
                powershell """
                    Write-Host "Recent Stack Events:"
                    aws cloudformation describe-stack-events `
                        --stack-name ${MAIN_STACK_NAME} `
                        --region ${AWS_DEFAULT_REGION} `
                        --query 'StackEvents[0:10].[Timestamp,LogicalResourceId,ResourceStatus,ResourceStatusReason]' `
                        --output table
                """
            }
        }
    }
}
