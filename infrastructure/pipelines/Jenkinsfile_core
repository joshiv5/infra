#!/usr/bin/env groovy

/**
 * Core Stack Deployment Pipeline
 * Deploys only the Core IAM Roles stack (stable, rarely changes)
 */

pipeline {
    agent any
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }
    
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'test', 'prod'],
            description: 'Select the environment'
        )
        choice(
            name: 'ACTION',
            choices: ['UPDATE', 'DELETE'],
            description: 'CloudFormation action (CREATE typically done once)'
        )
        string(
            name: 'AWS_REGION',
            defaultValue: 'us-east-1',
            description: 'AWS region'
        )
    }
    
    environment {
        PROJECT_NAME = 'ascend'
        STACK_TYPE = 'core'
    }
    
    stages {
        stage('Checkout & Validate') {
            steps {
                script {
                    checkout scm
                    
                    echo "========== Core Stack Deployment =========="
                    echo "Environment: ${params.ENVIRONMENT}"
                    echo "Action: ${params.ACTION}"
                    echo "Region: ${params.AWS_REGION}"
                    echo "==========================================="
                    
                    // Validate template
                    sh """
                        aws cloudformation validate-template \
                            --template-body file://infrastructure/cloudformation/core/core_iam_roles.yaml \
                            --region ${params.AWS_REGION}
                    """
                }
            }
        }
        
        stage('Deploy') {
            steps {
                script {
                    def stackName = "${PROJECT_NAME}-core-stack-${params.ENVIRONMENT}"
                    def templatePath = "${WORKSPACE}/infrastructure/cloudformation/core/core_iam_roles.yaml"
                    def paramFile = "${WORKSPACE}/infrastructure/configs/${params.ENVIRONMENT}/core_parameters.json"
                    
                    sh """
                        ./infrastructure/pipelines/utilities/deploy_stack.sh \
                            ${stackName} \
                            ${templatePath} \
                            ${paramFile} \
                            ${params.ACTION} \
                            ${params.AWS_REGION}
                    """
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
    }
}
