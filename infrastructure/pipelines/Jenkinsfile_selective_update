#!/usr/bin/env groovy

/**
 * Selective Stack Update Pipeline (Windows Compatible)
 * Updates only specific stacks (Core, Base, or App) without updating others
 * Usage: Update policies/resources in individual stacks independently
 * Works on: Windows Jenkins agents
 */

pipeline {
    agent any
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '10'))
        timeout(time: 1, unit: 'HOURS')
        timestamps()
        disableConcurrentBuilds()
    }
    
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'test', 'prod'],
            description: 'Select the environment to update'
        )
        booleanParam(
            name: 'UPDATE_CORE',
            defaultValue: false,
            description: 'Update Core IAM Roles Stack'
        )
        booleanParam(
            name: 'UPDATE_BASE',
            defaultValue: false,
            description: 'Update Base Stack (S3 + KMS)'
        )
        booleanParam(
            name: 'UPDATE_APP',
            defaultValue: false,
            description: 'Update App Specific Policies Stack'
        )
        string(
            name: 'AWS_REGION',
            defaultValue: 'eu-central-1',
            description: 'AWS region for deployment'
        )
        string(
            name: 'CF_TEMPLATES_BUCKET',
            defaultValue: 'ascend-test-poc',
            description: 'S3 bucket containing CloudFormation templates'
        )
        string(
            name: 'S3_TEMPLATES_PREFIX',
            defaultValue: 'infrastructure/cloudformation',
            description: 'S3 key prefix for CloudFormation templates (no leading/trailing slash)'
        )
        string(
            name: 'AWS_CREDENTIALS_ID',
            defaultValue: 'aws-credentials',
            description: 'Jenkins credentials ID for AWS access'
        )
        string(
            name: 'CHANGE_DESCRIPTION',
            defaultValue: 'Policy/Resource Updates',
            description: 'Description of changes for audit trail'
        )
        booleanParam(
            name: 'DRY_RUN',
            defaultValue: true,
            description: 'Preview changes via ChangeSets without applying'
        )
    }
    
    environment {
	    AWS_CREDS = credentials("${params.AWS_CREDENTIALS_ID}")
        AWS_DEFAULT_REGION = "${params.AWS_REGION}"
        S3_TEMPLATES_PREFIX = "${params.S3_TEMPLATES_PREFIX}"
        TEMPLATES_PATH = "${WORKSPACE}\\infrastructure\\cloudformation"
        CONFIGS_PATH = "${WORKSPACE}\\infrastructure\\configs"
        ENVIRONMENT = "${params.ENVIRONMENT}"
        BUILD_TIMESTAMP = "${BUILD_ID}"
    }
    
    stages {
        stage('Pre-Flight Check') {
            steps {
                script {
                    // Read PROJECT_NAME from parameters.json
                    def paramFile = "${CONFIGS_PATH}\\${ENVIRONMENT}\\parameters.json"
                    def paramJson = readFile(paramFile).trim()
                    env.PROJECT_NAME = extractParameterValue(paramJson, 'ProjectName')
                    echo "Project Name from parameters.json: ${PROJECT_NAME}"

                    echo "========== Selective Stack Update =========="
                    echo "Environment: ${ENVIRONMENT}"
                    echo "AWS Region: ${AWS_DEFAULT_REGION}"
                    echo "Change Description: ${params.CHANGE_DESCRIPTION}"
                    echo "Dry Run: ${params.DRY_RUN}"
                    echo ""
                    echo "Stacks to Update:"
                    echo "  - Core: ${params.UPDATE_CORE}"
                    echo "  - Base: ${params.UPDATE_BASE}"
                    if (params.UPDATE_APP) {
                        echo "  - App: ✓ (Cumulus, DataAPI, LeanRetina, Retina)"
                    } else {
                        echo "  - App: false"
                    }
                    echo "==========================================="
                    
                    // Validate that at least one stack is selected
                    if (!params.UPDATE_CORE && !params.UPDATE_BASE && !params.UPDATE_APP) {
                        error("ERROR: At least one stack must be selected for update!")
                    }
                    
                    // Production safety gates
                    if (ENVIRONMENT == 'prod') {
                        if (params.UPDATE_CORE) {
                            echo "⚠️  WARNING: Updating CORE stack in PRODUCTION"
                        }
                        if (params.UPDATE_BASE) {
                            echo "⚠️  WARNING: Updating BASE stack in PRODUCTION (affects S3/KMS)"
                        }
                        echo ""
                        input(message: "Are you sure you want to update these stacks in PRODUCTION?", ok: 'Proceed')
                    }
                }
            }
        }
        
        stage('Checkout') {
            steps {
                script {
                    echo "Checking out source code..."
                    checkout scm
                }
            }
        }
        
        stage('Discover Nested Stacks') {
            steps {
                script {
                    echo ""
                    echo "Discovering nested stack names from main stack..."
                    
                    def mainStackName = "${PROJECT_NAME}-main-stack-${ENVIRONMENT}"
                    
                    // Verify main stack exists before discovery
                    def mainExists = bat(script: """
                        @echo off
                        aws cloudformation describe-stacks ^
                            --stack-name ${mainStackName} ^
                            --region ${AWS_DEFAULT_REGION} >nul 2>&1
                        if %errorlevel% equ 0 (exit /b 0) else (exit /b 1)
                    """, returnStatus: true) == 0

                    if (!mainExists) {
                        error "Main stack '${mainStackName}' not found. Run the main pipeline first to create the stacks before using selective update."
                    }

                    // Level 1: Query direct nested stacks from the main stack (Core, Base, App)
                    bat """
                        @echo off
                        aws cloudformation describe-stack-resources ^
                            --stack-name ${mainStackName} ^
                            --region ${AWS_DEFAULT_REGION} ^
                            --query "StackResources[?ResourceType=='AWS::CloudFormation::Stack'].{Logical:LogicalResourceId,Physical:PhysicalResourceId}" ^
                            --output json > nested_stacks.json
                    """
                    
                    def nestedStacksJson = readFile('nested_stacks.json').trim()
                    echo "Main stack nested stacks:"
                    echo nestedStacksJson
                    
                    // Resolve Core, Base, App physical stack names
                    def mainDefaults = [:] as HashMap
                    def mainStacks = resolveStackNames(nestedStacksJson, mainDefaults)

                    if (!mainStacks.containsKey('CoreStack')) {
                        error "Could not discover CoreStack from main stack '${mainStackName}'. Ensure the main pipeline has been run successfully."
                    }
                    if (!mainStacks.containsKey('BaseStack')) {
                        error "Could not discover BaseStack from main stack '${mainStackName}'. Ensure the main pipeline has been run successfully."
                    }

                    env.CORE_STACK_NAME = mainStacks['CoreStack']
                    env.BASE_STACK_NAME = mainStacks['BaseStack']
                    env.APP_STACK_NAME = mainStacks.containsKey('AppStack') ? mainStacks['AppStack'] : ''
                    
                    echo ""
                    echo "Level 1 - Main stack children:"
                    echo "  Core: ${env.CORE_STACK_NAME}"
                    echo "  Base: ${env.BASE_STACK_NAME}"
                    echo "  App:  ${env.APP_STACK_NAME ?: '(not deployed)'}" 

                    // Level 2: Query nested stacks inside AppStack (Cumulus, Retina, DataAPI, LeanRetina)
                    if (params.UPDATE_APP) {
                        if (!env.APP_STACK_NAME) {
                            error "AppStack not found in main stack. Cannot update app role stacks. Run the main pipeline with DEPLOY_APP=true first."
                        }

                        bat """
                            @echo off
                            aws cloudformation describe-stack-resources ^
                                --stack-name ${env.APP_STACK_NAME} ^
                                --region ${AWS_DEFAULT_REGION} ^
                                --query "StackResources[?ResourceType=='AWS::CloudFormation::Stack'].{Logical:LogicalResourceId,Physical:PhysicalResourceId}" ^
                                --output json > app_nested_stacks.json
                        """

                        def appNestedJson = readFile('app_nested_stacks.json').trim()
                        echo ""
                        echo "App stack nested stacks:"
                        echo appNestedJson

                        def appDefaults = [:] as HashMap
                        def appStacks = resolveStackNames(appNestedJson, appDefaults)

                        // Validate all 4 role stacks were discovered
                        for (roleName in ['CumulusRolesStack', 'DataAPIRolesStack', 'LeanRetinaRolesStack', 'RetinaRolesStack']) {
                            if (!appStacks.containsKey(roleName)) {
                                error "Could not discover ${roleName} from AppStack. Ensure the main pipeline has been run successfully."
                            }
                        }

                        env.CUMULUS_STACK_NAME = appStacks['CumulusRolesStack']
                        env.DATAAPI_STACK_NAME = appStacks['DataAPIRolesStack']
                        env.LEANRETINA_STACK_NAME = appStacks['LeanRetinaRolesStack']
                        env.RETINA_STACK_NAME = appStacks['RetinaRolesStack']

                        echo ""
                        echo "Level 2 - App stack children:"
                        echo "  Cumulus:     ${env.CUMULUS_STACK_NAME}"
                        echo "  DataAPI:     ${env.DATAAPI_STACK_NAME}"
                        echo "  LeanRetina:  ${env.LEANRETINA_STACK_NAME}"
                        echo "  Retina:      ${env.RETINA_STACK_NAME}"
                    }
                    echo ""
                }
            }
        }
        
        stage('Validate Templates') {
            steps {
                script {
                    echo "Validating CloudFormation templates..."
                    
                    if (params.UPDATE_CORE) {
                        echo "✓ Validating Core stack template..."
                        bat """
                            aws cloudformation validate-template ^
                                --template-body file://${TEMPLATES_PATH}\\core\\core_iam_roles.yaml ^
                                --region ${AWS_DEFAULT_REGION}
                        """
                    }
                    
                    if (params.UPDATE_BASE) {
                        echo "✓ Validating Base stack template..."
                        bat """
                            aws cloudformation validate-template ^
                                --template-body file://${TEMPLATES_PATH}\\base\\base_s3_kms.yaml ^
                                --region ${AWS_DEFAULT_REGION}
                        """
                    }
                    
                    if (params.UPDATE_APP) {
                        echo "✓ Validating App stack templates..."
                        echo "  - Validating app_policies..."
                        bat """
                            aws cloudformation validate-template ^
                                --template-body file://${TEMPLATES_PATH}\\app\\app_policies.yaml ^
                                --region ${AWS_DEFAULT_REGION}
                        """
                        for (appType in ['cumulus', 'dataapi', 'leanretina', 'retina']) {
                            echo "  - Validating ${appType}..."
                            bat """
                                aws cloudformation validate-template ^
                                    --template-body file://${TEMPLATES_PATH}\\app\\${appType}\\roles.yaml ^
                                    --region ${AWS_DEFAULT_REGION}
                            """
                        }
                    }
                }
            }
        }
        
        stage('Upload Templates to S3') {
            steps {
                script {
                    echo "Uploading templates to S3..."
                    
                    if (params.UPDATE_CORE) {
                        bat """
                            aws s3 cp ${TEMPLATES_PATH}\\core\\core_iam_roles.yaml ^
                                s3://${params.CF_TEMPLATES_BUCKET}/${S3_TEMPLATES_PREFIX}/core/ ^
                                --region ${AWS_DEFAULT_REGION}
                            echo ✓ Core template uploaded
                        """
                    }
                    
                    if (params.UPDATE_BASE) {
                        bat """
                            aws s3 cp ${TEMPLATES_PATH}\\base\\base_s3_kms.yaml ^
                                s3://${params.CF_TEMPLATES_BUCKET}/${S3_TEMPLATES_PREFIX}/base/ ^
                                --region ${AWS_DEFAULT_REGION}
                            echo ✓ Base template uploaded
                        """
                    }
                    
                    if (params.UPDATE_APP) {
                        bat """
                            aws s3 cp ${TEMPLATES_PATH}\\app\\app_policies.yaml ^
                                s3://${params.CF_TEMPLATES_BUCKET}/${S3_TEMPLATES_PREFIX}/app/ ^
                                --region ${AWS_DEFAULT_REGION}
                            echo ✓ app_policies template uploaded
                        """
                        for (appType in ['cumulus', 'dataapi', 'leanretina', 'retina']) {
                            bat """
                                aws s3 cp ${TEMPLATES_PATH}\\app\\${appType}\\roles.yaml ^
                                    s3://${params.CF_TEMPLATES_BUCKET}/${S3_TEMPLATES_PREFIX}/app/${appType}/ ^
                                    --region ${AWS_DEFAULT_REGION}
                                echo ✓ ${appType} template uploaded
                            """
                        }
                    }
                }
            }
        }
        
        stage('Generate ChangeSets') {
            steps {
                script {
                    echo "Generating ChangeSets for review..."
                    
                    if (params.UPDATE_CORE) {
                        createAndDisplayChangeSet('core', env.CORE_STACK_NAME)
                    }
                    
                    if (params.UPDATE_BASE) {
                        createAndDisplayChangeSet('base', env.BASE_STACK_NAME)
                    }
                    
                    if (params.UPDATE_APP) {
                        createAndDisplayChangeSet('app', env.APP_STACK_NAME)
                        createAndDisplayChangeSet('cumulus', env.CUMULUS_STACK_NAME)
                        createAndDisplayChangeSet('dataapi', env.DATAAPI_STACK_NAME)
                        createAndDisplayChangeSet('leanretina', env.LEANRETINA_STACK_NAME)
                        createAndDisplayChangeSet('retina', env.RETINA_STACK_NAME)
                    }
                }
            }
        }
        
        stage('Review & Approval') {
            when {
                expression { params.ENVIRONMENT == 'prod' || params.DRY_RUN }
            }
            steps {
                script {
                    if (params.DRY_RUN) {
                        echo ""
                        echo "========== DRY RUN MODE =========="
                        echo "ChangeSets have been created but not executed."
                        echo "Review the changes above and re-run with DRY_RUN=false to apply."
                        echo "=================================="
                        echo ""
                    } else if (ENVIRONMENT == 'prod') {
                        input(message: "Review ChangeSets above. Approve to apply updates to PRODUCTION?", ok: 'Apply Updates')
                    }
                }
            }
        }
        
        stage('Apply Updates') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                script {
                    echo ""
                    echo "Applying stack updates..."
                    
                    if (params.UPDATE_CORE) {
                        updateStack('core', env.CORE_STACK_NAME)
                    }
                    
                    if (params.UPDATE_BASE) {
                        updateStack('base', env.BASE_STACK_NAME)
                    }
                    
                    if (params.UPDATE_APP) {
                        updateStack('app', env.APP_STACK_NAME)
                        updateStack('cumulus', env.CUMULUS_STACK_NAME)
                        updateStack('dataapi', env.DATAAPI_STACK_NAME)
                        updateStack('leanretina', env.LEANRETINA_STACK_NAME)
                        updateStack('retina', env.RETINA_STACK_NAME)
                    }
                    
                    echo ""
                    echo "✓ All selected stacks have been updated!"
                }
            }
        }
        
        stage('Verification') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                script {
                    echo ""
                    echo "Verifying updated stacks..."
                    
                    if (params.UPDATE_CORE) {
                        bat """
                            echo Checking Core stack status...
                            aws cloudformation describe-stacks ^
                                --stack-name ${CORE_STACK_NAME} ^
                                --query "Stacks[0].[StackStatus,StackStatusReason]" ^
                                --region ${AWS_DEFAULT_REGION}
                        """
                    }
                    
                    if (params.UPDATE_BASE) {
                        bat """
                            echo Checking Base stack status...
                            aws cloudformation describe-stacks ^
                                --stack-name ${BASE_STACK_NAME} ^
                                --query "Stacks[0].[StackStatus,StackStatusReason]" ^
                                --region ${AWS_DEFAULT_REGION}
                        """
                    }
                    
                    if (params.UPDATE_APP) {
                        bat """
                            echo Checking app stack status...
                            aws cloudformation describe-stacks ^
                                --stack-name ${APP_STACK_NAME} ^
                                --query "Stacks[0].[StackStatus,StackStatusReason]" ^
                                --region ${AWS_DEFAULT_REGION}
                        """
                        for (appType in ['cumulus', 'dataapi', 'leanretina', 'retina']) {
                            def stackVar = appType.toUpperCase() + '_STACK_NAME'
                            def stackName = env[stackVar]
                            bat """
                                echo Checking ${appType} stack status...
                                aws cloudformation describe-stacks ^
                                    --stack-name ${stackName} ^
                                    --query "Stacks[0].[StackStatus,StackStatusReason]" ^
                                    --region ${AWS_DEFAULT_REGION}
                            """
                        }
                    }
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo ""
                echo "========== Pipeline Summary =========="
                echo "Build Status: ${currentBuild.result}"
                echo "Environment: ${ENVIRONMENT}"
                echo "Build ID: ${BUILD_TIMESTAMP}"
                echo "====================================="
            }
        }
        success {
            script {
                if (params.DRY_RUN) {
                    echo "✓ Dry run completed successfully. Review changes and re-run with DRY_RUN=false to apply."
                } else {
                    echo "✓ Stack updates completed successfully!"
                }
            }
        }
        failure {
            script {
                echo "✗ Pipeline failed! Check the logs above for details."
            }
        }
    }
}

/**
 * Helper function: Create and display ChangeSet
 */
def createAndDisplayChangeSet(stackType, stackName) {
    def changeSetName = "${stackType}-changeset-${BUILD_ID}"
    
    // Construct S3 template URL based on stack type
    def templateUrl = getTemplateUrl(stackType)
    
    // Construct parameter file path - use consolidated parameters.json for all stacks
    def paramFile = "${CONFIGS_PATH}\\${ENVIRONMENT}\\parameters.json"
    
    if (stackType == 'app') {
        // For app_policies, inject template URLs and stack outputs
        paramFile = buildAppPoliciesParameters(paramFile)
    } else if (stackType == 'core') {
        // Core stack only needs base parameters
        paramFile = mergeCoreStackParameters(paramFile)
    } else if (stackType == 'base') {
        // For Base stack, merge Core stack outputs
        paramFile = mergeBaseStackParameters(paramFile)
    }
    // Individual app stacks (cumulus, dataapi, leanretina, retina) only need
    // base parameters (EnvironmentName, EnvironmentTag, ProjectName) - no merging needed
    
    bat """
        echo.
        echo Creating UPDATE ChangeSet for ${stackType} stack...
        echo Stack: ${stackName}
        echo Template: ${templateUrl}
        
        aws cloudformation create-change-set ^
            --stack-name ${stackName} ^
            --change-set-name ${changeSetName} ^
            --change-set-type UPDATE ^
            --template-url ${templateUrl} ^
            --parameters file://${paramFile} ^
            --capabilities CAPABILITY_NAMED_IAM ^
            --region ${AWS_DEFAULT_REGION}
        
        echo Waiting for changeset to be created...
        aws cloudformation wait change-set-create-complete ^
            --stack-name ${stackName} ^
            --change-set-name ${changeSetName} ^
            --region ${AWS_DEFAULT_REGION} 2>nul || echo (ChangeSet may have no changes)
        
        echo.
        echo ChangeSet Status:
        aws cloudformation describe-change-set ^
            --stack-name ${stackName} ^
            --change-set-name ${changeSetName} ^
            --region ${AWS_DEFAULT_REGION} ^
            --query "[Status, StatusReason]" ^
            --output text
        
        echo.
        echo ChangeSet for ${stackType.toUpperCase()} Stack:
        echo ==========================================
        aws cloudformation describe-change-set ^
            --stack-name ${stackName} ^
            --change-set-name ${changeSetName} ^
            --region ${AWS_DEFAULT_REGION} ^
            --query "Changes[*].[Type,ResourceChange.Action,ResourceChange.LogicalResourceId,ResourceChange.ResourceType]" ^
            --output table || echo (No changes)
        echo ==========================================
    """
}

/**
 * Helper function: Execute stack update or create
 */
def updateStack(stackType, stackName) {
    // Construct S3 template URL based on stack type
    def templateUrl = getTemplateUrl(stackType)
    
    // Construct parameter file path - use consolidated parameters.json for all stacks
    def paramFile = "${CONFIGS_PATH}\\${ENVIRONMENT}\\parameters.json"
    
    if (stackType == 'app') {
        // For app_policies, inject template URLs and stack outputs
        paramFile = buildAppPoliciesParameters(paramFile)
    } else if (stackType == 'core') {
        // Core stack only needs base parameters
        paramFile = mergeCoreStackParameters(paramFile)
    } else if (stackType == 'base') {
        // For Base stack, merge Core stack outputs
        paramFile = mergeBaseStackParameters(paramFile)
    }
    // Individual app stacks (cumulus, dataapi, leanretina, retina) only need
    // base parameters (EnvironmentName, EnvironmentTag, ProjectName) - no merging needed
    
    bat """
        echo.
        echo ========== UPDATING ${stackType.toUpperCase()} Stack ==========
        
        aws cloudformation update-stack ^
            --stack-name ${stackName} ^
            --template-url ${templateUrl} ^
            --parameters file://${paramFile} ^
            --capabilities CAPABILITY_NAMED_IAM ^
            --region ${AWS_DEFAULT_REGION}
        
        echo Waiting for stack update to complete...
        aws cloudformation wait stack-update-complete ^
            --stack-name ${stackName} ^
            --region ${AWS_DEFAULT_REGION}
        
        echo ✓ ${stackType.toUpperCase()} stack updated successfully
        echo.
    """
}

/**
 * Helper function: Get S3 template URL for a stack type
 */
def getTemplateUrl(stackType) {
    def s3Base = "https://${params.CF_TEMPLATES_BUCKET}.s3.${AWS_DEFAULT_REGION}.amazonaws.com/${S3_TEMPLATES_PREFIX}"
    def templates = [
        'core': "${s3Base}/core/core_iam_roles.yaml",
        'base': "${s3Base}/base/base_s3_kms.yaml",
        'app': "${s3Base}/app/app_policies.yaml",
        'cumulus': "${s3Base}/app/cumulus/roles.yaml",
        'dataapi': "${s3Base}/app/dataapi/roles.yaml",
        'leanretina': "${s3Base}/app/leanretina/roles.yaml",
        'retina': "${s3Base}/app/retina/roles.yaml"
    ]
    return templates[stackType]
}

/**
 * Helper function: Core Stack only needs base parameters (EnvironmentName, EnvironmentTag, ProjectName)
 * No stack outputs needed - just return the base parameter file as-is
 */
def mergeCoreStackParameters(coreParamFile) {
    echo "Core stack uses base parameters only - no merging needed"
    return coreParamFile
}

/**
 * Helper function: Merge Base Stack parameters with specific Core stack outputs
 * Base template only needs S3BucketRoleArn and KMSKeyRoleArn from Core stack
 */
def mergeBaseStackParameters(baseParamFile) {
    echo "Fetching specific Core stack outputs for Base stack..."

    def baseParams = readFile(baseParamFile).trim()
    echo "Original base parameters: ${baseParams}"

    def s3BucketRoleArn = bat(script: """
        @echo off
        aws cloudformation describe-stacks ^
            --stack-name ${CORE_STACK_NAME} ^
            --region ${AWS_DEFAULT_REGION} ^
            --query "Stacks[0].Outputs[?OutputKey=='S3BucketRoleArn'].OutputValue" ^
            --output text
    """, returnStdout: true).trim()
    echo "S3BucketRoleArn: ${s3BucketRoleArn}"

    def kmsKeyRoleArn = bat(script: """
        @echo off
        aws cloudformation describe-stacks ^
            --stack-name ${CORE_STACK_NAME} ^
            --region ${AWS_DEFAULT_REGION} ^
            --query "Stacks[0].Outputs[?OutputKey=='KMSKeyRoleArn'].OutputValue" ^
            --output text
    """, returnStdout: true).trim()
    echo "KMSKeyRoleArn: ${kmsKeyRoleArn}"

    def extraEntries = '{"ParameterKey":"S3BucketRoleArn","ParameterValue":"' + s3BucketRoleArn + '"},' +
        '{"ParameterKey":"KMSKeyRoleArn","ParameterValue":"' + kmsKeyRoleArn + '"}'

    def finalJson = appendJsonEntries(baseParams, extraEntries)

    def mergedParamFile = "${WORKSPACE}\\base_parameters_merged.json"
    writeFile file: mergedParamFile, text: finalJson

    echo "Final merged Base parameters: ${finalJson}"
    return mergedParamFile
}

/**
 * Helper function: Build App Policies parameters with template URLs
 */
def buildAppPoliciesParameters(appParamFile) {
    echo "Building app_policies parameters with template URLs and stack outputs..."

    def appParams = readFile(appParamFile).trim()
    echo "Original app parameters: ${appParams}"

    // Fetch only the specific outputs needed by app_policies.yaml
    // S3BucketName and KMSKeyId from Base stack
    def s3BucketName = bat(script: """
        @echo off
        aws cloudformation describe-stacks ^
            --stack-name ${BASE_STACK_NAME} ^
            --region ${AWS_DEFAULT_REGION} ^
            --query "Stacks[0].Outputs[?OutputKey=='S3BucketName'].OutputValue" ^
            --output text
    """, returnStdout: true).trim()
    echo "S3BucketName: ${s3BucketName}"

    def kmsKeyId = bat(script: """
        @echo off
        aws cloudformation describe-stacks ^
            --stack-name ${BASE_STACK_NAME} ^
            --region ${AWS_DEFAULT_REGION} ^
            --query "Stacks[0].Outputs[?OutputKey=='KMSKeyId'].OutputValue" ^
            --output text
    """, returnStdout: true).trim()
    echo "KMSKeyId: ${kmsKeyId}"

    // S3BucketRoleArn from Core stack
    def s3BucketRoleArn = bat(script: """
        @echo off
        aws cloudformation describe-stacks ^
            --stack-name ${CORE_STACK_NAME} ^
            --region ${AWS_DEFAULT_REGION} ^
            --query "Stacks[0].Outputs[?OutputKey=='S3BucketRoleArn'].OutputValue" ^
            --output text
    """, returnStdout: true).trim()
    echo "S3BucketRoleArn: ${s3BucketRoleArn}"

    // Build extra parameter entries: 3 stack outputs + 4 template URLs
    def cumulusUrl = "https://${params.CF_TEMPLATES_BUCKET}.s3.${AWS_DEFAULT_REGION}.amazonaws.com/${S3_TEMPLATES_PREFIX}/app/cumulus/roles.yaml"
    def dataapiUrl = "https://${params.CF_TEMPLATES_BUCKET}.s3.${AWS_DEFAULT_REGION}.amazonaws.com/${S3_TEMPLATES_PREFIX}/app/dataapi/roles.yaml"
    def leanretinaUrl = "https://${params.CF_TEMPLATES_BUCKET}.s3.${AWS_DEFAULT_REGION}.amazonaws.com/${S3_TEMPLATES_PREFIX}/app/leanretina/roles.yaml"
    def retinaUrl = "https://${params.CF_TEMPLATES_BUCKET}.s3.${AWS_DEFAULT_REGION}.amazonaws.com/${S3_TEMPLATES_PREFIX}/app/retina/roles.yaml"

    def extraEntries = '{"ParameterKey":"S3BucketName","ParameterValue":"' + s3BucketName + '"},' +
        '{"ParameterKey":"KMSKeyId","ParameterValue":"' + kmsKeyId + '"},' +
        '{"ParameterKey":"S3BucketRoleArn","ParameterValue":"' + s3BucketRoleArn + '"},' +
        '{"ParameterKey":"CumulusRolesTemplateURL","ParameterValue":"' + cumulusUrl + '"},' +
        '{"ParameterKey":"DataAPIRolesTemplateURL","ParameterValue":"' + dataapiUrl + '"},' +
        '{"ParameterKey":"LeanRetinaRolesTemplateURL","ParameterValue":"' + leanretinaUrl + '"},' +
        '{"ParameterKey":"RetinaRolesTemplateURL","ParameterValue":"' + retinaUrl + '"}'

    def finalJson = appendJsonEntries(appParams, extraEntries)

    def mergedParamFile = "${WORKSPACE}\\app_policies_parameters_merged.json"
    writeFile file: mergedParamFile, text: finalJson

    echo "Final app_policies parameters: ${finalJson}"
    return mergedParamFile
}

/**
 * @NonCPS: Extracts a parameter value by key from a JSON parameter array.
 */
@NonCPS
def extractParameterValue(String jsonText, String key) {
    def slurper = new groovy.json.JsonSlurper()
    def params = slurper.parseText(jsonText)
    for (int i = 0; i < params.size(); i++) {
        if (params[i].ParameterKey == key) {
            return params[i].ParameterValue
        }
    }
    return ''
}

/**
 * @NonCPS: Appends raw JSON entries to a base parameters JSON array.
 * Used by buildAppPoliciesParameters to inject template URL entries.
 */
@NonCPS
def appendJsonEntries(String baseParamsJson, String extraEntries) {
    def inner = ''
    if (baseParamsJson.startsWith('[') && baseParamsJson.endsWith(']')) {
        inner = baseParamsJson.substring(1, baseParamsJson.length() - 1).trim()
    } else {
        inner = baseParamsJson.trim()
    }
    if (inner.length() > 0) {
        return '[' + inner + ',' + extraEntries + ']'
    } else {
        return '[' + extraEntries + ']'
    }
}

/**
 * @NonCPS: Parse nested stacks JSON and resolve physical stack names.
 * Maps LogicalResourceId to PhysicalResourceId for discovered nested stacks.
 * Returns a plain HashMap<String,String> (CPS-serializable) with only discovered stacks.
 */
@NonCPS
def resolveStackNames(String jsonText, Map<String,String> defaults) {
    def result = new HashMap<String,String>(defaults)
    try {
        def jsonSlurper = new groovy.json.JsonSlurper()
        def stacks = jsonSlurper.parseText(jsonText) ?: []
        for (int i = 0; i < stacks.size(); i++) {
            def logical = (stacks[i].Logical ?: '').toString()
            def physical = (stacks[i].Physical ?: '').toString()
            if (logical && physical) {
                result[logical] = physical
            }
        }
    } catch (Exception e) {
        // Return defaults on parse failure
    }
    return result
}
